{
	"name": "voicevox-tts",
	"displayName": "VOICEVOX TTS for Claude Code",
	"description": "tts_input.jsonを監視してVOICEVOXで音声再生する",
	"version": "2.2.1",
	"repository": {
		"type": "git",
		"url": "https://github.com/j-mayama/prj-vscode-extension.git"
	},
	"engines": {
		"vscode": "^1.85.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [
		"onStartupFinished"
	],
	"main": "./extension.js",
	"extensionKind": [
		"ui"
	],
	"contributes": {
		"commands": [
			{
				"command": "voicevox-tts.setup",
				"title": "VOICEVOX: Setup Wizard"
			},
			{
				"command": "voicevox-tts.setupDocker",
				"title": "VOICEVOX: Setup Docker Integration"
			}
		]
	},
	"scripts": {
		"package": "vsce package --no-dependencies"
	},
	"devDependencies": {
		"@vscode/vsce": "3.9.2"
	}
}
